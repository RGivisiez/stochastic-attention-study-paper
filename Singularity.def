Bootstrap: docker
From: ubuntu:22.04

%labels
    Author stock_attn
    Description Julia 1.12.5 + HMMER runtime for stochastic-attention reproduction

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export JULIA_DEPOT_PATH=/opt/julia_depot
    export PATH=/opt/julia/bin:$PATH

%post
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates wget curl git bash gzip xz-utils bzip2 \
        build-essential pkg-config hmmer python3 python3-pip \
        && rm -rf /var/lib/apt/lists/*

    mkdir -p /opt/julia /opt/julia_depot
    wget -q https://julialang-s3.julialang.org/bin/linux/x64/1.12/julia-1.12.5-linux-x86_64.tar.gz
    tar -xzf julia-1.12.5-linux-x86_64.tar.gz
    mv julia-1.12.5/* /opt/julia/
    rm -rf julia-1.12.5 julia-1.12.5-linux-x86_64.tar.gz

    /opt/julia/bin/julia -e 'using Pkg; Pkg.Registry.add("General")'

%runscript
    exec /bin/bash "$@"
