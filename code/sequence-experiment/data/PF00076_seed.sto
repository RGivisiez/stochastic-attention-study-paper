#=GF ID   RRM_1
#=GF AC   PF00076.29
#=GF DE   RNA recognition motif
#=GF PI   rrm;
#=GF AU   Eddy SR;0000-0001-6676-4706
#=GF AU   Birney E;0000-0001-8314-8497
#=GF SE   Published_alignment
